  <joint name="right_wrist_yaw" type="revolute">
    <parent link="right_forearm_link"/>
    <child link="right_hand_base_link"/>
    <origin rpy="0 -1.5707963267948966 0" xyz="0 0.00021 0.0917"/>
    <axis xyz="0 0 1"/>
    <limit effort="10" lower="-0.17453292519943295" upper="0.17453292519943295" velocity="1.0"/>
  </joint>

  <link name="right_hand_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.252893"/>
      <inertia ixx="0.0002839" ixy="0.000003336317" ixz="0.000004077546" iyy="0.0001891" iyz="0.000000331897" izz="0.0001469"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="package://robot_description/meshes/hand/visual/hand.dae" scale="0.1 0.1 0.1"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="package://robot_description/meshes/hand/collision/hand.stl" scale="0.1 0.1 0.1"/></geometry>
    </collision>
  </link>

  <joint name="right_hand_wrist_pitch" type="revolute">
    <parent link="right_hand_base_link"/>
    <child link="right_hand_link"/>
    <origin rpy="0 1.5707963267948966 0" xyz="0.029887 0.007923 0"/>
