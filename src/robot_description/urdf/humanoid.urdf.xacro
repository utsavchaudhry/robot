    <axis xyz="0 0 -1"/>
    <limit effort="10" lower="-0.7853981633974483" upper="3.665191429188092" velocity="1.0"/>
  </joint>

  <link name="right_hand_base_link">
    <inertial>
      <origin xyz="-0.02 0 0.028" rpy="0 0 0"/>
      <mass value="0.03323"/>
      <inertia ixx="0.000018824494" ixy="-0.000000571474" ixz="-0.000000041098" iyy="0.00001505929" iyz="0.000000023636" izz="0.000013661405"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
